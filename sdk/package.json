{
  "name": "@gooddollar/agent-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for AI agents to interact with all GoodDollar L2 protocols",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --no-cache",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "gooddollar",
    "l2",
    "agent",
    "sdk",
    "defi",
    "ubi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoniassia/gooddollar-l2.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/yoniassia/gooddollar-l2/tree/main/sdk#readme",
  "engines": {
    "node": ">=18"
  }
}
